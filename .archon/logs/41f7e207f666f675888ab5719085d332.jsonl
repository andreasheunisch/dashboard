{"type":"tool","tool_name":"Write","tool_input":{"file_path":"/home/andreas/.archon/worktrees/ai/dashboard/archon/task-feat-calculator-keyboard-navigation/public/calculator/index.html","content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Calculator — Dashboard</title>\n  <style>\n    * {\n      margin: 0;\n      padding: 0;\n      box-sizing: border-box;\n    }\n\n    body {\n      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n      background: #0f1117;\n      color: #e2e8f0;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n      min-height: 100vh;\n      gap: 1.5rem;\n    }\n\n    .back-link {\n      color: #6366f1;\n      text-decoration: none;\n      font-size: 0.875rem;\n      align-self: center;\n    }\n\n    .back-link:hover {\n      text-decoration: underline;\n    }\n\n    .calculator {\n      background: #1a1d27;\n      border: 1px solid #2d3148;\n      border-radius: 16px;\n      padding: 1.25rem;\n      display: flex;\n      flex-direction: column;\n      gap: 0.75rem;\n      width: 280px;\n    }\n\n    /* Task 1.2: .display updated for <input> — strip browser chrome, fill container */\n    .display {\n      background: #0f1117;\n      border: 1px solid #2d3148;\n      border-radius: 8px;\n      padding: 0.75rem 1rem;\n      font-size: 2rem;\n      font-weight: 300;\n      letter-spacing: -0.02em;\n      color: #e2e8f0;\n      overflow: hidden;\n      white-space: nowrap;\n      min-height: 3.5rem;\n      text-align: right;\n      outline: none;\n      width: 100%;\n    }\n\n    /* Task 1.3: caret visibility — hide by default, show only when display is focused */\n    #display { caret-color: transparent; }\n    #display:focus { caret-color: auto; }\n\n    .buttons {\n      display: grid;\n      grid-template-columns: repeat(4, 1fr);\n      gap: 0.5rem;\n    }\n\n    button {\n      border: none;\n      border-radius: 8px;\n      padding: 0.875rem 0;\n      font-size: 1.1rem;\n      font-weight: 500;\n      cursor: pointer;\n      transition: filter 0.1s;\n    }\n\n    button:active {\n      filter: brightness(1.25);\n    }\n\n    .btn-digit {\n      background: #252836;\n      color: #e2e8f0;\n    }\n\n    .btn-digit:hover {\n      background: #2d3148;\n    }\n\n    .btn-operator {\n      background: #3730a3;\n      color: #c7d2fe;\n    }\n\n    .btn-operator:hover {\n      background: #4338ca;\n    }\n\n    .btn-equals {\n      background: #6366f1;\n      color: #fff;\n    }\n\n    .btn-equals:hover {\n      background: #4f46e5;\n    }\n\n    .btn-clear {\n      background: #7f1d1d;\n      color: #fca5a5;\n    }\n\n    .btn-clear:hover {\n      background: #991b1b;\n    }\n\n    .span-two {\n      grid-column: span 2;\n    }\n\n    .btn-memory {\n      background: #374151;\n      color: #9ca3af;\n    }\n\n    .btn-memory:hover {\n      background: #4b5563;\n    }\n\n    .calculator-header {\n      display: flex;\n      justify-content: flex-end;\n    }\n\n    #btn-sci {\n      background: #252836;\n      color: #9ca3af;\n      border: 1px solid #2d3148;\n      border-radius: 6px;\n      padding: 0.25rem 0.5rem;\n      font-size: 0.75rem;\n      cursor: pointer;\n    }\n\n    #btn-sci:hover {\n      background: #2d3148;\n    }\n\n    .sci-panel {\n      display: grid;\n      grid-template-columns: repeat(7, 1fr);\n      gap: 0.35rem;\n    }\n\n    .sci-panel[hidden] {\n      display: none;\n    }\n\n    .sci-panel.row-4 {\n      grid-template-columns: repeat(5, 1fr);\n    }\n\n    #angle-unit-label {\n      display: none;\n      text-align: right;\n      font-size: 0.7rem;\n      color: #6b7280;\n      padding: 0 0.25rem;\n    }\n\n    .btn-sci-fn {\n      background: #1e3a4a;\n      color: #67c5d0;\n      border: none;\n      border-radius: 6px;\n      padding: 0.5rem 0;\n      font-size: 0.85rem;\n      font-weight: 500;\n      cursor: pointer;\n      transition: filter 0.1s;\n    }\n\n    .btn-sci-fn:hover {\n      background: #264d5e;\n    }\n\n    .btn-sci-fn:active {\n      filter: brightness(1.25);\n    }\n  </style>\n</head>\n<body>\n  <a class=\"back-link\" href=\"/\">← Back to Dashboard</a>\n\n  <div class=\"calculator\">\n    <div class=\"calculator-header\">\n      <button id=\"btn-sci\" onclick=\"calc.toggleSci()\">[sci]</button>\n    </div>\n    <!-- Task 1.1: replaced <div> with <input> for native cursor positioning -->\n    <input type=\"text\" class=\"display\" id=\"display\" value=\"0\" spellcheck=\"false\" autocomplete=\"off\">\n    <span id=\"angle-unit-label\">RAD</span>\n    <div class=\"sci-panel\" id=\"sci-panel\" hidden>\n      <button class=\"btn-sci-fn\" onclick=\"calc.applyUnary(function(x){return Math.sin(calc.toRadians(x))})\">sin</button>\n      <button class=\"btn-sci-fn\" onclick=\"calc.applyUnary(function(x){return Math.cos(calc.toRadians(x))})\">cos</button>\n      <button class=\"btn-sci-fn\" onclick=\"calc.applyUnary(function(x){return Math.tan(calc.toRadians(x))})\">tan</button>\n      <button class=\"btn-sci-fn\" onclick=\"calc.applyUnary(function(x){return calc.fromRadians(Math.asin(x))})\">arcsin</button>\n      <button class=\"btn-sci-fn\" onclick=\"calc.applyUnary(function(x){return calc.fromRadians(Math.acos(x))})\">arccos</button>\n      <button class=\"btn-sci-fn\" onclick=\"calc.applyUnary(function(x){return calc.fromRadians(Math.atan(x))})\">arctan</button>\n      <button class=\"btn-sci-fn\" onclick=\"calc.applyUnary(function(x){return x===0?NaN:1/x})\">1/x</button>\n      <button class=\"btn-sci-fn\" onclick=\"calc.applyUnary(function(x){return x<=0?NaN:Math.log10(x)})\">log</button>\n      <button class=\"btn-sci-fn\" onclick=\"calc.applyUnary(function(x){return x<=0?NaN:Math.log(x)})\">ln</button>\n      <button class=\"btn-sci-fn\" onclick=\"calc.applyUnary(function(x){return x<0?NaN:Math.sqrt(x)})\">√</button>\n      <button class=\"btn-sci-fn\" onclick=\"calc.applyUnary(function(x){return x*x})\">x²</button>\n      <button class=\"btn-sci-fn\" onclick=\"calc.powerOp()\">xʸ</button>\n      <button class=\"btn-sci-fn\" onclick=\"calc.insertConstant(Math.PI)\">π</button>\n      <button class=\"btn-sci-fn\" onclick=\"calc.insertConstant(Math.E)\">e</button>\n    </div>\n    <div class=\"sci-panel row-4\" id=\"sci-panel-2\" hidden>\n      <button class=\"btn-sci-fn\" onclick=\"calc.negate()\">±</button>\n      <button class=\"btn-sci-fn\" onclick=\"calc.applyUnary(function(x){return x/100})\">%</button>\n      <button class=\"btn-sci-fn\" onclick=\"calc.openParen()\">(</button>\n      <button class=\"btn-sci-fn\" onclick=\"calc.closeParen()\">)</button>\n      <button class=\"btn-sci-fn\" onclick=\"calc.toggleAngleUnit()\">RAD</button>\n    </div>\n    <div class=\"buttons\">\n      <button class=\"btn-memory\" onclick=\"calc.memoryClear()\">MC</button>\n      <button class=\"btn-memory\" onclick=\"calc.memoryRecall()\">MR</button>\n      <button class=\"btn-memory\" onclick=\"calc.memoryAdd()\">M+</button>\n      <button class=\"btn-memory\" style=\"visibility: hidden;\"></button>\n\n      <button class=\"btn-clear span-two\" onclick=\"calc.clear()\">C</button>\n      <button class=\"btn-operator\" onclick=\"calc.inputOperator('÷')\">÷</button>\n      <button class=\"btn-operator\" onclick=\"calc.inputOperator('×')\">×</button>\n\n      <button class=\"btn-digit\" onclick=\"calc.inputDigit('7')\">7</button>\n      <button class=\"btn-digit\" onclick=\"calc.inputDigit('8')\">8</button>\n      <button class=\"btn-digit\" onclick=\"calc.inputDigit('9')\">9</button>\n      <button class=\"btn-operator\" onclick=\"calc.inputOperator('−')\">−</button>\n\n      <button class=\"btn-digit\" onclick=\"calc.inputDigit('4')\">4</button>\n      <button class=\"btn-digit\" onclick=\"calc.inputDigit('5')\">5</button>\n      <button class=\"btn-digit\" onclick=\"calc.inputDigit('6')\">6</button>\n      <button class=\"btn-operator\" onclick=\"calc.inputOperator('+')\">+</button>\n\n      <button class=\"btn-digit\" onclick=\"calc.inputDigit('1')\">1</button>\n      <button class=\"btn-digit\" onclick=\"calc.inputDigit('2')\">2</button>\n      <button class=\"btn-digit\" onclick=\"calc.inputDigit('3')\">3</button>\n      <button class=\"btn-equals\" style=\"grid-row: span 2;\" onclick=\"calc.evaluate()\">=</button>\n\n      <button class=\"btn-digit span-two\" onclick=\"calc.inputDigit('0')\">0</button>\n      <button class=\"btn-digit\" onclick=\"calc.inputDecimal()\">.</button>\n    </div>\n  </div>\n\n  <script>\n    const display = document.getElementById('display');\n\n    function formatDisplay(value) {\n      if (value === 'Error' || value === '0') return value;\n      const n = parseFloat(value);\n      if (!isFinite(n) || isNaN(n)) return 'Error';\n      if (n === 0) return '0';\n      const abs = Math.abs(n);\n      if (value.length <= 12 && abs >= 1e-6 && abs < 1e12) return value;\n      for (let p = 10; p >= 0; p--) {\n        let s = n.toExponential(p);\n        s = s.replace(/\\.?0+(e)/, '$1');\n        s = s.replace('e', 'E');\n        s = s.replace(/E(\\d)/, 'E+$1');\n        if (s.endsWith('E+0')) {\n          const decimals = 12 - 2 - (n < 0 ? 1 : 0);\n          return n.toFixed(decimals).replace(/\\.?0+$/, '');\n        }\n        if (s.length <= 12) return s;\n      }\n      let s = n.toExponential(0);\n      s = s.replace('e', 'E');\n      s = s.replace(/E(\\d)/, 'E+$1');\n      return s;\n    }\n\n    // Task 4.1: returns all focusable (visible, enabled) buttons\n    function getFocusableButtons() {\n      return Array.from(document.querySelectorAll('button')).filter(function(btn) {\n        if (btn.disabled) return false;\n        if (btn.hidden) return false;\n        const style = window.getComputedStyle(btn);\n        if (style.visibility === 'hidden') return false;\n        if (style.display === 'none') return false;\n        return true;\n      });\n    }\n\n    // Task 4.2: spatially navigate buttons in the given arrow direction\n    function navigateButtons(direction) {\n      const active = document.activeElement;\n      const activeRect = active.getBoundingClientRect();\n      const cx = (activeRect.left + activeRect.right) / 2;\n      const cy = (activeRect.top + activeRect.bottom) / 2;\n\n      const buttons = getFocusableButtons();\n      const candidates = buttons.filter(function(btn) {\n        if (btn === active) return false;\n        const r = btn.getBoundingClientRect();\n        const bx = (r.left + r.right) / 2;\n        const by = (r.top + r.bottom) / 2;\n        if (direction === 'ArrowRight') return bx > cx;\n        if (direction === 'ArrowLeft')  return bx < cx;\n        if (direction === 'ArrowDown')  return by > cy;\n        if (direction === 'ArrowUp')    return by < cy;\n        return false;\n      });\n\n      if (candidates.length === 0) return;\n\n      let best = null;\n      let bestDist = Infinity;\n      candidates.forEach(function(btn) {\n        const r = btn.getBoundingClientRect();\n        const bx = (r.left + r.right) / 2;\n        const by = (r.top + r.bottom) / 2;\n        const dist = Math.sqrt((bx - cx) * (bx - cx) + (by - cy) * (by - cy));\n        if (dist < bestDist) {\n          bestDist = dist;\n          best = btn;\n        }\n      });\n\n      if (best) best.focus();\n    }\n\n    const calc = {\n      currentInput: '0',\n      previousInput: null,\n      operator: null,\n      waitingForOperand: false,\n      memoryValue: 0,\n      parenDepth: 0,\n      contextStack: [],\n      angleUnit: 'RAD',\n\n      toRadians(x) {\n        switch (this.angleUnit) {\n          case 'DEG': return x * Math.PI / 180;\n          case 'GON': return x * Math.PI / 200;\n          default: return x;\n        }\n      },\n\n      fromRadians(x) {\n        switch (this.angleUnit) {\n          case 'DEG': return x * 180 / Math.PI;\n          case 'GON': return x * 200 / Math.PI;\n          default: return x;\n        }\n      },\n\n      toggleAngleUnit() {\n        const cycle = { RAD: 'GON', GON: 'DEG', DEG: 'RAD' };\n        this.angleUnit = cycle[this.angleUnit];\n        document.getElementById('angle-unit-label').textContent = this.angleUnit;\n        document.querySelector('#sci-panel-2 button:last-child').textContent = this.angleUnit;\n      },\n\n      roundResult(n) {\n        if (!isFinite(n)) return n;\n        const rounded = parseFloat(n.toPrecision(10));\n        if (Math.abs(rounded) < 1e-10) return 0;\n        return rounded;\n      },\n\n      // Task 1.4: use display.value instead of display.textContent;\n      // preserve cursor position when display is focused\n      updateDisplay() {\n        if (display === document.activeElement) {\n          const start = display.selectionStart;\n          const end = display.selectionEnd;\n          display.value = formatDisplay(this.currentInput);\n          display.setSelectionRange(start, end);\n        } else {\n          display.value = formatDisplay(this.currentInput);\n        }\n      },\n\n      // Task 2.2: cursor-aware digit insertion when display is focused\n      inputDigit(digit) {\n        if (this.waitingForOperand) {\n          this.currentInput = digit;\n          this.waitingForOperand = false;\n          this.updateDisplay();\n          return;\n        }\n        if (display === document.activeElement && display.selectionStart === display.selectionEnd) {\n          if (this.currentInput.length >= 12) return;\n          const pos = display.selectionStart;\n          if (this.currentInput === '0') {\n            this.currentInput = digit;\n            this.updateDisplay();\n            display.setSelectionRange(1, 1);\n          } else {\n            this.currentInput = this.currentInput.slice(0, pos) + digit + this.currentInput.slice(pos);\n            this.updateDisplay();\n            display.setSelectionRange(pos + 1, pos + 1);\n          }\n          return;\n        }\n        if (this.currentInput.length >= 12) return;\n        this.currentInput = this.currentInput === '0'\n          ? digit\n          : this.currentInput + digit;\n        this.updateDisplay();\n      },\n\n      // Task 2.3: cursor-aware decimal insertion when display is focused\n      inputDecimal() {\n        if (this.waitingForOperand) {\n          this.currentInput = '0.';\n          this.waitingForOperand = false;\n          this.updateDisplay();\n          return;\n        }\n        if (display === document.activeElement) {\n          if (this.currentInput.includes('.')) return;\n          const pos = display.selectionStart;\n          if (this.currentInput.length >= 12) return;\n          this.currentInput = this.currentInput.slice(0, pos) + '.' + this.currentInput.slice(pos);\n          this.updateDisplay();\n          display.setSelectionRange(pos + 1, pos + 1);\n          return;\n        }\n        if (!this.currentInput.includes('.')) {\n          if (this.currentInput.length >= 12) return;\n          this.currentInput += '.';\n          this.updateDisplay();\n        }\n      },\n\n      inputOperator(op) {\n        // If there's a pending operation, evaluate it first\n        if (this.operator && !this.waitingForOperand) {\n          this.evaluate();\n          if (this.currentInput === 'Error') return;\n        }\n        this.previousInput = this.currentInput;\n        this.operator = op;\n        this.waitingForOperand = true;\n      },\n\n      evaluate() {\n        if (this.operator === null || this.previousInput === null) return;\n\n        const a = parseFloat(this.previousInput);\n        const b = parseFloat(this.currentInput);\n        let result;\n\n        switch (this.operator) {\n          case '+': result = a + b; break;\n          case '−': result = a - b; break;\n          case '×': result = a * b; break;\n          case '÷':\n            if (b === 0) {\n              this.currentInput = 'Error';\n              this.operator = null;\n              this.previousInput = null;\n              this.waitingForOperand = false;\n              this.updateDisplay();\n              return;\n            }\n            result = a / b;\n            break;\n          case 'pow': result = Math.pow(a, b); break;\n          default: return;\n        }\n\n        // Avoid floating point noise for simple cases\n        this.currentInput = parseFloat(result.toPrecision(12)).toString();\n        this.operator = null;\n        this.previousInput = null;\n        this.waitingForOperand = true;\n        this.updateDisplay();\n      },\n\n      clear() {\n        this.currentInput = '0';\n        this.previousInput = null;\n        this.operator = null;\n        this.waitingForOperand = false;\n        this.parenDepth = 0;\n        this.contextStack = [];\n        this.updateDisplay();\n      },\n\n      memoryAdd() {\n        if (this.currentInput === 'Error') return;\n        this.memoryValue += parseFloat(this.currentInput);\n        this.waitingForOperand = true;\n      },\n\n      memoryRecall() {\n        this.currentInput = this.memoryValue.toString();\n        this.waitingForOperand = false;\n        this.updateDisplay();\n      },\n\n      memoryClear() {\n        this.memoryValue = 0;\n      },\n\n      applyUnary(fn) {\n        if (this.currentInput === 'Error') return;\n        const x = parseFloat(this.currentInput);\n        const result = fn(x);\n        if (isNaN(result) || !isFinite(result)) {\n          this.currentInput = 'Error';\n        } else {\n          this.currentInput = this.roundResult(result).toString();\n        }\n        this.waitingForOperand = true;\n        this.updateDisplay();\n      },\n\n      negate() {\n        if (this.currentInput === 'Error' || this.currentInput === '0') return;\n        if (this.currentInput.startsWith('-')) {\n          this.currentInput = this.currentInput.slice(1);\n        } else {\n          this.currentInput = '-' + this.currentInput;\n        }\n        this.updateDisplay();\n      },\n\n      insertConstant(val) {\n        this.currentInput = val.toString();\n        this.waitingForOperand = true;\n        this.updateDisplay();\n      },\n\n      powerOp() {\n        if (this.operator && !this.waitingForOperand) {\n          this.evaluate();\n          if (this.currentInput === 'Error') return;\n        }\n        this.previousInput = this.currentInput;\n        this.operator = 'pow';\n        this.waitingForOperand = true;\n      },\n\n      openParen() {\n        this.contextStack.push({\n          previousInput: this.previousInput,\n          operator: this.operator,\n        });\n        this.parenDepth++;\n        this.currentInput = '0';\n        this.waitingForOperand = false;\n        this.previousInput = null;\n        this.operator = null;\n        this.updateDisplay();\n      },\n\n      closeParen() {\n        if (this.parenDepth === 0) {\n          this.currentInput = 'Error';\n          this.updateDisplay();\n          return;\n        }\n        // If there's a pending operation inside the parens, resolve it\n        if (this.operator && this.previousInput !== null) {\n          const a = parseFloat(this.previousInput);\n          const b = parseFloat(this.currentInput);\n          let result;\n          switch (this.operator) {\n            case '+': result = a + b; break;\n            case '−': result = a - b; break;\n            case '×': result = a * b; break;\n            case '÷':\n              if (b === 0) {\n                this.currentInput = 'Error';\n                this.operator = null;\n                this.previousInput = null;\n                this.waitingForOperand = false;\n                this.parenDepth--;\n                this.contextStack.pop();\n                this.updateDisplay();\n                return;\n              }\n              result = a / b;\n              break;\n            case 'pow': result = Math.pow(a, b); break;\n            default: result = b;\n          }\n          if (isNaN(result) || !isFinite(result)) {\n            this.currentInput = 'Error';\n            this.operator = null;\n            this.previousInput = null;\n            this.waitingForOperand = false;\n            this.parenDepth--;\n            this.contextStack.pop();\n            this.updateDisplay();\n            return;\n          }\n          this.currentInput = this.roundResult(result).toString();\n          this.operator = null;\n          this.previousInput = null;\n        }\n        // Restore outer context so the paren result combines with the outer expression\n        const outer = this.contextStack.pop();\n        if (outer && outer.operator !== null) {\n          this.previousInput = outer.previousInput;\n          this.operator = outer.operator;\n        }\n        this.parenDepth--;\n        this.waitingForOperand = false;\n        this.updateDisplay();\n      },\n\n      toggleSci() {\n        const panel = document.getElementById('sci-panel');\n        const panel2 = document.getElementById('sci-panel-2');\n        const btn = document.getElementById('btn-sci');\n        const label = document.getElementById('angle-unit-label');\n        const isHidden = panel.hidden;\n        panel.hidden = !isHidden;\n        panel2.hidden = !isHidden;\n        label.style.display = isHidden ? 'block' : 'none';\n        if (isHidden) label.textContent = this.angleUnit;\n        btn.textContent = isHidden ? '[basic]' : '[sci]';\n      },\n\n      // Task 2.1: start a new number entry from a button-focus state\n      startNewEntry(digit) {\n        this.waitingForOperand = true;\n        this.inputDigit(digit);\n        display.focus();\n      },\n    };\n\n    // Task 1.5: prevent direct user edits to the display input;\n    // always re-sync value from calc state\n    display.addEventListener('input', function(e) {\n      e.preventDefault();\n      display.value = formatDisplay(calc.currentInput);\n    });\n\n    // Tasks 3.1–3.5, 4.3–4.5: revised keydown handler with per-key routing\n    document.addEventListener('keydown', function(e) {\n      const ae = document.activeElement;\n      const tag = ae ? ae.tagName : '';\n\n      // Task 3.1: suppress only for non-calculator form inputs (not the display)\n      if ((tag === 'INPUT' && ae !== display) || tag === 'TEXTAREA' || tag === 'SELECT') return;\n\n      // Task 4.4 / 4.5: when display is focused, handle arrow keys\n      if (ae === display) {\n        if (e.key === 'ArrowUp' || e.key === 'ArrowDown') {\n          // Task 4.5: ArrowUp/Down from display → navigate to nearest button\n          navigateButtons(e.key);\n          e.preventDefault();\n          return;\n        }\n        // Task 4.4: ArrowLeft/ArrowRight — do NOT intercept; allow native cursor movement\n      }\n\n      // Tasks 3.2–3.5 / 4.3: routing when a button is focused\n      if (tag === 'BUTTON') {\n        // Task 3.2: digit key — start new entry (focus returns to display)\n        if (e.key >= '0' && e.key <= '9') {\n          e.preventDefault();\n          calc.startNewEntry(e.key);\n          return;\n        }\n        // Task 3.3: decimal key — start new entry with '.'\n        if (e.key === '.') {\n          e.preventDefault();\n          calc.startNewEntry('.');\n          return;\n        }\n        // Task 3.4: = or Enter — let the focused button's own click fire; skip global handler\n        if (e.key === '=' || e.key === 'Enter') {\n          return;\n        }\n        // Task 4.3: arrow keys — spatial navigation between buttons\n        if (e.key === 'ArrowLeft' || e.key === 'ArrowRight' ||\n            e.key === 'ArrowUp'   || e.key === 'ArrowDown') {\n          navigateButtons(e.key);\n          e.preventDefault();\n          return;\n        }\n        // Task 3.5: operator keys — fall through to global operator handling below\n      }\n\n      // Global digit/operator handling (display focused, or button focused with operator key)\n      if (e.key >= '0' && e.key <= '9') {\n        e.preventDefault();\n        calc.inputDigit(e.key);\n      } else if (e.key === '.') {\n        e.preventDefault();\n        calc.inputDecimal();\n      } else if (e.key === '+') {\n        calc.inputOperator('+');\n      } else if (e.key === '-') {\n        calc.inputOperator('\\u2212');\n      } else if (e.key === '*') {\n        calc.inputOperator('\\u00d7');\n      } else if (e.key === '/') {\n        e.preventDefault();\n        calc.inputOperator('\\u00f7');\n      } else if (e.key === '=' || e.key === 'Enter') {\n        calc.evaluate();\n      }\n    });\n  </script>\n</body>\n</html>\n"},"workflow_id":"41f7e207f666f675888ab5719085d332","ts":"2026-04-20T13:18:39.646Z"}
